QLineEdit#CmdDescription:focus,QLineEdit#CmdBoxNoteTitle:focus,QLineEdit#CmdBoxCategory:focus,QLineEdit#CmdBoxSubCategory:focus,QLineEdit#CmdBoxTags:focus,QLineEdit#CmdBoxProgram:focus,QLineEdit#CmdBoxDescription:focus{border:1px solid #0069ff;background:#202020}
QTextEdit#CmdCommand,QTextEdit#CmdBoxCommand{background:#1e1e1e;border:1px solid #2b2b2b;border-radius:14px;padding:10px 12px;selection-background-color:#2b2b2b;selection-color:#0069ff}
